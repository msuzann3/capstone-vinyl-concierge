# Copy this file to ".env" (which is gitignored) and fill in your real values.
# NEVER commit the real .env or serviceAccount.json.

# Discogs personal access token (from discogs.com/settings/developers).
# Used ONLY by scripts/seedAlbums.mjs on your machine, never in the browser.
DISCOGS_TOKEN=your-discogs-personal-access-token

# The Firebase service account key is a separate JSON file, not an env var.
# Download it from: Firebase console > Project settings > Service accounts >
# Generate new private key, and save it as serviceAccount.json next to package.json.
