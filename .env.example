# No secret is required for the browser app or GitHub Pages build.
# These local-only values are used only when seeding Firestore from Discogs.

# Discogs personal access token from discogs.com/settings/developers.
DISCOGS_TOKEN=your-discogs-personal-access-token

# Also save the Firebase Admin SDK private key as:
# serviceAccount.json

# Optional public n8n webhook for the tester feedback form.
# In n8n, use a Webhook trigger, then append the received JSON to Google Sheets.
VITE_N8N_FEEDBACK_WEBHOOK_URL=https://your-n8n-domain/webhook/vinyl-concierge-feedback
